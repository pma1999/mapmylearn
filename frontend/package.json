{
  "name": "mapmylearn-frontend",
  "version": "1.0.0",
  "description": "Frontend for MapMyLearn - Course Generator",
  "main": "index.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "cross-env DISABLE_ESLINT_PLUGIN=true react-scripts build && node ./scripts/generate-sitemap.js",
    "analyze": "npx source-map-explorer 'build/static/js/*.js' --html build/report.html | cat",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "patch-package"
  },
  "keywords": [
    "learning",
    "path",
    "generator",
    "react"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@mui/x-date-pickers": "^5.0.20",
    "@stripe/stripe-js": "^7.2.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "axios": "^1.12.0",
    "date-fns": "^2.29.3",
    "dompurify": "^3.2.4",
    "framer-motion": "^12.6.3",
    "html-to-image": "^1.11.13",
    "mermaid": "^11.9.0",
    "prismjs": "1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-joyride": "^2.9.3",
    "react-markdown": "^10.1.0",
    "react-router": "^7.12.0",
    "react-syntax-highlighter": "^15.5.0",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^1.8.11",
    "react-zoom-pan-pinch": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "yocto-queue": "^1.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "cross-env": "^10.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "glob": ">=11.1.0",
    "http-proxy-middleware": "^3.0.5",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "react-router-sitemap": "^1.2.0",
    "react-scripts": "^5.0.1",
    "source-map-explorer": "^2.5.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "prismjs": "^1.30.0",
    "refractor/prismjs": "^1.30.0"
  },
  "overrides": {
    "nth-check": ">=2.0.1",
    "schema-utils": "^4.3.3",
    "ajv": "^8.17.1",
    "ajv-keywords": "^5.1.0",
    "node-forge": "^1.3.2",
    "express": "^4.22.0",
    "@isaacs/brace-expansion": ">=5.0.1",
    "qs": ">=6.14.1",
    "mdast-util-to-hast": ">=13.2.1",
    "webpack-dev-server": ">=5.2.1"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!(axios|react-markdown|remark-gfm|devlop)/)"
    ]
  },
  "homepage": "https://mapmylearn.com/"
}